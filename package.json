{
  "name": "zk-faucet",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:circuits && bun run build:frontend",
    "build:frontend": "bun run --filter frontend build",
    "build:circuits": "cd packages/circuits/bin/eth_balance && nargo compile",
    "dev": "bun run --elide-lines 2000 --filter server dev",
    "start": "bun run --filter server start",
    "test": "bun run --filter '*' test",
    "test:circuits": "bun run --filter circuits test",
    "test:unit": "bun run --filter server test",
    "test:e2e": "bun run --filter e2e test"
  }
}
