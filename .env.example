# =============================================================================
# zk_faucet — Environment Configuration (single .env)
# =============================================================================
# All config lives here. The server loads this via --env-file=../../.env.
# Vite reads this via envDir: '../..' — only VITE_* vars reach the browser.
#
# Copy to .env:  cp .env.example .env
# =============================================================================

# === Shared (server + frontend) ===
# VITE_ prefix required for Vite to expose these to the browser.
# The server reads them with the same names — the prefix is harmless.

# [REQUIRED] Minimum ETH balance required (in wei).
VITE_MIN_BALANCE_WEI=1000000000000000

# [OPTIONAL] Epoch duration in seconds (default: 604800 = 1 week).
VITE_EPOCH_DURATION=604800

# [OPTIONAL] Default origin chain for wallet connection (default: 1 = Ethereum mainnet).
# The frontend gets the full list of supported origin chains from /modules at runtime.
VITE_ORIGIN_CHAINID=1

# [OPTIONAL] Reown project ID for WalletConnect relay.
# Get one at https://cloud.reown.com
# Without this, only injected wallets (MetaMask, etc.) will work.
VITE_REOWN_PROJECT_ID=

# === Server-only ===

# [REQUIRED] Faucet wallet private key (0x-prefixed, holds testnet funds).
FAUCET_PRIVATE_KEY=0x...

# Server config
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# SQLite database path
DB_PATH=./data/nullifiers.db

# CORS allowed origins (default: *)
ALLOWED_ORIGINS=*

# Origin chain RPCs (mainnet, optional — falls back to public RPCs)
# ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Testnet RPCs (optional — falls back to public RPCs)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# === Docker / Caddy ===

# [OPTIONAL] Domain for Caddy reverse proxy (default: localhost).
DOMAIN=localhost
