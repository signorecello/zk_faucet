# =============================================================================
# zk_faucet — Frontend Environment (root .env)
# =============================================================================
# This file is read by Vite at build time (envDir: '../..' in vite.config.ts).
# Only VITE_* variables are exposed to the browser.
#
# Copy to .env:  cp .env.example .env
# =============================================================================

# [REQUIRED] Origin chain ID for balance proofs.
# Supported: 1 (mainnet), 11155111 (sepolia), 17000 (holesky)
VITE_ORIGIN_CHAINID=1

# [REQUIRED] Minimum ETH balance required (in wei).
VITE_MIN_BALANCE_WEI=1000000000000000

# [OPTIONAL] Reown project ID for WalletConnect relay.
# Get one at https://cloud.reown.com
# Without this, only injected wallets (MetaMask, etc.) will work.
VITE_REOWN_PROJECT_ID=
