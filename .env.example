# =============================================================================
# zk_faucet — Shared Environment (root .env)
# =============================================================================
# Shared config is defined here once. The server loads this via --env-file.
# Vite reads this via envDir: '../..' — only VITE_* vars reach the browser.
#
# Copy to .env:  cp .env.example .env
# =============================================================================

# === Shared Configuration (server + frontend) ===

# [REQUIRED] Minimum ETH balance required (in wei).
MIN_BALANCE_WEI=1000000000000000

# [OPTIONAL] Epoch duration in seconds (default: 604800 = 1 week).
EPOCH_DURATION=604800

# === Frontend aliases (Vite requires VITE_ prefix for browser exposure) ===
VITE_MIN_BALANCE_WEI=$MIN_BALANCE_WEI
VITE_EPOCH_DURATION=$EPOCH_DURATION

# [OPTIONAL] Default origin chain for wallet connection (default: 1 = Ethereum mainnet).
# The frontend gets the full list of supported origin chains from /modules at runtime.
VITE_ORIGIN_CHAINID=1

# === Frontend-only ===

# [OPTIONAL] Reown project ID for WalletConnect relay.
# Get one at https://cloud.reown.com
# Without this, only injected wallets (MetaMask, etc.) will work.
VITE_REOWN_PROJECT_ID=
