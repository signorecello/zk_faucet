# =============================================================================
# zk_faucet Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set. All others have sane defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# [REQUIRED] Ethereum Mainnet RPC
# -----------------------------------------------------------------------------
# Used to fetch state roots for ZK proof verification.
# Any Ethereum L1 RPC works: Alchemy, Infura, public endpoints, local node.
ORIGIN_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# -----------------------------------------------------------------------------
# [REQUIRED] Faucet Wallet Private Key
# -----------------------------------------------------------------------------
# Hex-encoded private key (must start with 0x) of the wallet that holds
# testnet funds. This wallet signs dispensation transactions on target networks.
# NEVER commit this value to version control.
FAUCET_PRIVATE_KEY=0x...

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the HTTP server listens on.
PORT=3000

# Bind address. Use 0.0.0.0 for all interfaces, 127.0.0.1 for local only.
HOST=0.0.0.0

# Pino log level: debug | info | warn | error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Maximum number of requests per IP address within the window.
RATE_LIMIT_MAX=10

# Rate limit window duration in milliseconds (default: 1 minute).
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Faucet Parameters
# -----------------------------------------------------------------------------
# Amount of testnet ETH to dispense per successful claim (in ETH, not wei).
DISPENSATION_AMOUNT=0.1

# Epoch duration in seconds. Each epoch resets nullifiers, allowing users to
# claim again. Default: 604800 (1 week).
EPOCH_DURATION=604800

# Minimum ETH balance required on Ethereum mainnet to be eligible (in wei).
# Default: 10000000000000000 (0.01 ETH).
MIN_BALANCE_WEI=10000000000000000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Path to the SQLite database for nullifier storage.
# The directory will be created automatically if it doesn't exist.
DB_PATH=./data/nullifiers.db

# -----------------------------------------------------------------------------
# Testing / Debugging (optional)
# -----------------------------------------------------------------------------
# Skip the CLI's early balance check so proof generation proceeds even when
# the wallet has insufficient mainnet ETH. The circuit will still enforce the
# minimum balance constraint, so the proof will fail at the ZK level.
# TEST_ALLOW_BELOW_BALANCE=1

# -----------------------------------------------------------------------------
# Per-Network RPC Overrides (optional)
# -----------------------------------------------------------------------------
# Override the default RPC URL for any target network defined in networks.json.
# Format: <NETWORK_ID>_RPC_URL (uppercase, hyphens replaced with underscores)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# HOLESKY_RPC_URL=https://eth-holesky.g.alchemy.com/v2/YOUR_KEY
