# =============================================================================
# zk_faucet — Server Environment (packages/server/.env)
# =============================================================================
# Server-specific config only. Shared vars (ORIGIN_CHAINID, MIN_BALANCE_WEI,
# EPOCH_DURATION, ORIGIN_RPC_URL) are defined in the root .env and loaded
# via --env-file=../../.env in package.json scripts.
#
# Copy to .env:  cp .env.example .env
# =============================================================================

# [REQUIRED] Faucet wallet private key (0x-prefixed, holds testnet funds).
FAUCET_PRIVATE_KEY=0x...

# Server config
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# SQLite database path
DB_PATH=./data/nullifiers.db

# CORS allowed origins (default: *)
ALLOWED_ORIGINS=*

# Testnet RPC URLs (optional, falls back to public RPCs)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
