# =============================================================================
# zk_faucet — Server Environment (packages/server/.env)
# =============================================================================
# Copy to .env:  cp .env.example .env
# =============================================================================

# [REQUIRED] Origin chain ID (must match the chain ORIGIN_RPC_URL points to).
# Supported: 1 (mainnet), 11155111 (sepolia), 17000 (holesky)
ORIGIN_CHAINID=1

# [REQUIRED] Minimum ETH balance required (in wei).
MIN_BALANCE_WEI=1000000000000000

# [REQUIRED] Origin chain RPC URL (for state root verification).
ORIGIN_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# [REQUIRED] Faucet wallet private key (0x-prefixed, holds testnet funds).
FAUCET_PRIVATE_KEY=0x...

# Server config
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Epoch duration in seconds (default: 1 week)
EPOCH_DURATION=604800

# SQLite database path
DB_PATH=./data/nullifiers.db

# Testnet RPC URLs (optional, falls back to public RPCs)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
